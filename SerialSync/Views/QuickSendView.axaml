<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonia="using:Material.Icons.Avalonia"
             xmlns:models="using:SerialSync.Models"
             xmlns:vm="using:SerialSync.ViewModels"
             x:Class="SerialSync.Views.QuickSendView"
             x:Name="QuickRoot"
             Classes="vs-panel"
             x:DataType="vm:QuickSendViewModel">
  <DockPanel>
    <Border DockPanel.Dock="Top" Classes="vs-toolbar">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock VerticalAlignment="Center" FontSize="11"
                   Foreground="{DynamicResource VsTextMutedBrush}"
                   Text="一键发送 · 在「发送」面板输入后点此保存" />
        <Button Grid.Column="1" Classes="vs-tool-btn" Command="{Binding SaveFromSendPanelCommand}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <avalonia:MaterialIcon Kind="ContentSaveOutline" Width="14" Height="14" />
            <TextBlock Text="从发送面板保存" FontSize="12" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <ListBox Classes="vs-history" ItemsSource="{Binding QuickCommands}">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="models:QuickCommand">
          <Grid ColumnDefinitions="*,Auto,Auto" Classes="vs-history-item">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding Payload}" Opacity="0.65" FontSize="11" TextTrimming="CharacterEllipsis"
                         ToolTip.Tip="{Binding Payload}" />
            </StackPanel>
            <Button Grid.Column="1" Classes="vs-tool-btn" Margin="4,0,0,0"
                    Command="{Binding #QuickRoot.((vm:QuickSendViewModel)DataContext).RunQuickCommandCommand}"
                    CommandParameter="{Binding}">
              <avalonia:MaterialIcon Kind="Send" Width="14" Height="14" />
            </Button>
            <Button Grid.Column="2" Classes="vs-tool-btn"
                    Command="{Binding #QuickRoot.((vm:QuickSendViewModel)DataContext).DeleteQuickCommandCommand}"
                    CommandParameter="{Binding}">
              <avalonia:MaterialIcon Kind="Close" Width="14" Height="14" />
            </Button>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
