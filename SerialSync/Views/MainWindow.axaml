<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:SerialSync.Views"
        xmlns:vm="using:SerialSync.ViewModels"
        x:Class="SerialSync.Views.MainWindow"
        ViewModelLocator.AutoWireViewModel="True"
        x:DataType="vm:MainWindowViewModel"
        Title="SerialSync — 串口调试"
        Width="1360"
        Height="860"
        MinWidth="900"
        MinHeight="560"
        Background="{DynamicResource VsBgBrush}">
  <views:MainView />
</Window>
