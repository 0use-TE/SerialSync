<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonia="using:Material.Icons.Avalonia"
             xmlns:vm="using:SerialSync.ViewModels"
             x:Class="SerialSync.Views.ReceiveView"
             Classes="vs-panel"
             x:DataType="vm:ReceiveViewModel">
  <DockPanel>
    <Border DockPanel.Dock="Top" Classes="vs-toolbar">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Button Classes="vs-tool-btn" Command="{Binding ToggleFormatCommand}" ToolTip.Tip="切换文本/HEX 显示">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <avalonia:MaterialIcon Kind="CodeBraces" Width="14" Height="14" />
            <TextBlock Text="{Binding DisplayFormatLabel}" FontSize="12" />
          </StackPanel>
        </Button>
        <Border Width="1" Height="16" Background="{DynamicResource VsBorderBrush}" Margin="4,0" VerticalAlignment="Center" />
        <Button Classes="vs-tool-btn" Command="{Binding ClearCommand}" ToolTip.Tip="清空接收缓冲">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <avalonia:MaterialIcon Kind="DeleteOutline" Width="14" Height="14" />
            <TextBlock Text="清空" FontSize="12" />
          </StackPanel>
        </Button>
        <Button x:Name="SaveReceiveButton" Classes="vs-tool-btn" ToolTip.Tip="保存接收区到文件">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <avalonia:MaterialIcon Kind="ContentSaveOutline" Width="14" Height="14" />
            <TextBlock Text="保存" FontSize="12" />
          </StackPanel>
        </Button>
        <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" FontSize="11"
                   Foreground="{DynamicResource VsTextMutedBrush}"
                   Text="{Binding TotalBytes, StringFormat=RX {0} B}" />
      </StackPanel>
    </Border>

    <ScrollViewer x:Name="ReceiveScroll"
                  MinHeight="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  Background="{DynamicResource VsCodeBgBrush}">
      <SelectableTextBlock x:Name="ReceiveText"
                           Classes="vs-code"
                           Text="{Binding DisplayText}"
                           TextWrapping="Wrap"
                           Padding="8,6" />
    </ScrollViewer>
  </DockPanel>
</UserControl>
