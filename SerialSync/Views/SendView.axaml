<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonia="using:Material.Icons.Avalonia"
             xmlns:models="using:SerialSync.Models"
             xmlns:vm="using:SerialSync.ViewModels"
             x:Class="SerialSync.Views.SendView"
             Classes="vs-panel"
             x:DataType="vm:SendViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+Enter" Command="{Binding SendCommand}" />
    <KeyBinding Gesture="Ctrl+Return" Command="{Binding SendCommand}" />
  </UserControl.KeyBindings>
  <DockPanel>
    <Border DockPanel.Dock="Top" Classes="vs-toolbar">
      <Border.Resources>
        <ResourceDictionary>
          <ResourceDictionary.MergedDictionaries>
            <ResourceInclude Source="avares://SerialSync/Styles/VsSemiToolbarInput.axaml" />
          </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
      </Border.Resources>
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
        <ComboBox Grid.Column="0" Classes="vs-toolbar-combo" Width="88" MinHeight="26" FontSize="12" Margin="0,0,6,0"
                  ItemsSource="{Binding SendFormats}" SelectedItem="{Binding SendFormat}" />
        <ComboBox Grid.Column="1" Classes="vs-toolbar-combo" Width="96" MinHeight="26" FontSize="12" Margin="0,0,6,0"
                  IsVisible="{Binding IsTextMode}"
                  ItemsSource="{Binding LineEndings}" SelectedItem="{Binding LineEnding}" />
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
          <Button Classes="vs-tool-btn" Command="{Binding SendCommand}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <avalonia:MaterialIcon Kind="Send" Width="14" Height="14" />
              <TextBlock Text="发送 (Ctrl+Enter)" FontSize="12" />
            </StackPanel>
          </Button>
          <Button x:Name="SendFileButton" Classes="vs-tool-btn">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <avalonia:MaterialIcon Kind="FileUploadOutline" Width="14" Height="14" />
              <TextBlock Text="发送文件" FontSize="12" />
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="8,0,0,0" VerticalAlignment="Center">
          <TextBlock FontSize="11" Foreground="{DynamicResource VsTextMutedBrush}" Text="间隔" />
          <TextBox Width="52" MinHeight="24" FontSize="12" Text="{Binding PeriodicIntervalMs}" />
          <TextBlock FontSize="11" Foreground="{DynamicResource VsTextMutedBrush}" Text="ms" />
          <Button Classes="vs-tool-btn" Command="{Binding TogglePeriodicSendCommand}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <avalonia:MaterialIcon Kind="Repeat" Width="14" Height="14" />
              <TextBlock Text="{Binding PeriodicSendButtonText}" FontSize="12" />
            </StackPanel>
          </Button>
        </StackPanel>
        <TextBlock Grid.Column="5" VerticalAlignment="Center" FontSize="11"
                   Foreground="{DynamicResource VsTextMutedBrush}"
                   Text="{Binding StatusText}" />
      </Grid>
    </Border>

    <Grid ColumnDefinitions="200,*">
      <DockPanel Grid.Column="0" Background="{DynamicResource VsSidebarBgBrush}">
        <TextBlock DockPanel.Dock="Top" Margin="8,6,8,4" FontSize="11"
                   Foreground="{DynamicResource VsTextMutedBrush}" Text="历史 · 双击重发" />
        <ListBox x:Name="HistoryList" Classes="vs-history" ItemsSource="{Binding History.Items}"
                 SelectedItem="{Binding SelectedHistoryItem}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:SendRecord">
              <Grid ColumnDefinitions="*,Auto" Classes="vs-history-item">
                <TextBlock Grid.Column="0" Text="{Binding Preview}" TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Preview}" />
                <TextBlock Grid.Column="1" Opacity="0.6" FontSize="11"
                           Text="{Binding ByteCount, StringFormat={}{0}B}" Margin="6,0,0,0" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>

      <Border Grid.Column="1" BorderBrush="{DynamicResource VsBorderSubtleBrush}" BorderThickness="1,0,0,0">
        <Border.Resources>
          <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
              <ResourceInclude Source="avares://SerialSync/Styles/VsSemiCodeInput.axaml" />
            </ResourceDictionary.MergedDictionaries>
          </ResourceDictionary>
        </Border.Resources>
        <TextBox x:Name="SendInputBox"
                 Classes="vs-code"
                 Text="{Binding InputText}"
                 PlaceholderText="Text / HEX 输入&#x0a;Ctrl+Enter 发送"
                 VerticalAlignment="Stretch"
                 VerticalContentAlignment="Top">
          <TextBox.KeyBindings>
            <KeyBinding Gesture="Ctrl+Enter" Command="{Binding SendCommand}" />
            <KeyBinding Gesture="Ctrl+Return" Command="{Binding SendCommand}" />
          </TextBox.KeyBindings>
        </TextBox>
      </Border>
    </Grid>
  </DockPanel>
</UserControl>
